rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['score', 'survivalTime', 'proton', 'neutron', 'electron', 'isotope', 'elementName', 'guestId', 'createdAt']) &&
        request.resource.data.score is number &&
        request.resource.data.survivalTime is number &&
        request.resource.data.proton is number &&
        request.resource.data.neutron is number &&
        request.resource.data.electron is number &&
        request.resource.data.isotope is string &&
        request.resource.data.elementName is string &&
        request.resource.data.guestId is string &&
        request.resource.data.createdAt is number;
      // No updates or deletes to prevent tampering
      allow update, delete: if false;
    }
  }
}
